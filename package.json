{
  "name": "hyperwallet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "db:seed": "tsx scripts/seed-wallets.ts",
    "db:indexes": "tsx scripts/ensure-indexes.ts",
    "wallet:sync": "tsx scripts/sync-wallets.ts"
  },
  "dependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.37.3",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "dotenv": "^17.4.2",
    "mongoose": "^9.7.1",
    "svelte": "^5.45.12",
    "vite": "^7.2.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte-check": "^4.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
