PORT=3002
NODE_ENV=development

# Phase 2 DB option: isolated Hyperwallet DB
MONGODB_URI=mongodb://127.0.0.1:27017/celestial_hyperwallet
HYPERWALLET_DB_NAME=celestial_hyperwallet

# Optional shared DB mode if approved later
# MONGODB_URI=mongodb://127.0.0.1:27017/celestial
# HYPERWALLET_COLLECTION_PREFIX=hyperwallet_

# Optional main-app API proxy after API contract is approved
MAIN_APP_API_URL=http://localhost:3001

# Phase 3 Hyperliquid public API client
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
HYPERLIQUID_NETWORK=mainnet
HYPERLIQUID_REQUEST_TIMEOUT_MS=15000
HYPERLIQUID_MAX_RETRIES=2
HYPERLIQUID_RETRY_DELAY_MS=750

# Phase 6 Push notifications (VAPID)
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# PUSH_EMAIL=admin@hyperwallet.local
